# Environment variables template for the portfolio backend

PORT=5000
NODE_ENV=development

# Database Connection URL:
# Format: postgres://username:password@hostname:port/database_name
# Example for local pgAdmin: postgres://postgres:password123@localhost:5432/my_portfolio
DATABASE_URL=postgres://your_db_user:your_db_password@your_db_host:5432/your_db_name
